# Public API base URL (browser + server; use same origin or gateway URL in dev)
NEXT_PUBLIC_API_URL=http://localhost/api

# Optional: server-side fetch target for the login BFF (defaults to NEXT_PUBLIC_API_URL).
# INTERNAL_API_URL=http://auth-service:8001/api

# HS256 secret shared with the auth service for JWT cookies (middleware verifies refresh JWT).
# When set in auth-service as AUTH_JWT_SECRET, it must match this value.
AUTH_JWT_SECRET=

# Optional: override default refresh cookie name `ilb.refresh_token`
# AUTH_REFRESH_COOKIE_NAME=
