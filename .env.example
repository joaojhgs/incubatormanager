# Copy to `.env` and adjust for local runs: `cp .env.example .env`
# Compose reads this file from the repository root when you run `make up`.

# --- PostgreSQL (superuser + per-service DB passwords; used by init script) ---
POSTGRES_PASSWORD=postgres-dev-change-me
AUTH_DB_PASSWORD=auth-db-dev
COMPANY_DB_PASSWORD=company-db-dev
CONTRACT_DB_PASSWORD=contract-db-dev
FINANCE_DB_PASSWORD=finance-db-dev
SPACE_DB_PASSWORD=space-db-dev
BOOKING_DB_PASSWORD=booking-db-dev
INVENTORY_DB_PASSWORD=inventory-db-dev
TICKET_DB_PASSWORD=ticket-db-dev
DASHBOARD_DB_PASSWORD=dashboard-db-dev
DOCUMENT_DB_PASSWORD=document-db-dev

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-real-deployments

# JWT signing key (HS256). scripts/generate-env.sh replaces this with a random hex key;
# delete or comment out to fall back to DJANGO_SECRET_KEY instead.
AUTH_JWT_SECRET=change-me

# --- Auth dev users (`python manage.py seed_dev_users` in services/auth-service) ---
# Required for the command: shared password for all seeded users unless overrides below are set.
AUTH_DEV_SEED_PASSWORD=change-me-dev-seed-users
# Optional per-role overrides (otherwise AUTH_DEV_SEED_PASSWORD is used):
# AUTH_DEV_SEED_DIRECTOR_PASSWORD=
# AUTH_DEV_SEED_STAFF_PASSWORD=
# AUTH_DEV_SEED_CLIENT_PASSWORD=

# --- MinIO (S3-compatible document storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-change-me

# --- Frontend (browser) ---
# Gateway serves the API under `/api` on the same host in compose.
NEXT_PUBLIC_API_URL=http://localhost/api
